function saveNewDay() {
  const dow   = document.getElementById('nd_dow').value;
  const dateN = document.getElementById('nd_date').value;
  const month = document.getElementById('nd_month').value;
  const subj  = document.getElementById('nd_subj').value;
  const sess  = parseInt(document.getElementById('nd_sess').value) || 1;
  if (!dateN) { alert('กรุณาใส่วันที่'); return; }
  const maxN = days.reduce((m,d) => Math.max(m,d.n), 0);
  const newDay = {
    n: maxN+1,
    dow, 
    date: dateN+' '+month+' 2569',
    month,
    classes: [{s:subj, sess}]
  };
  days.push(newDay);
  // re-sort by date
  days.sort((a,b) => parseDay(a) - parseDay(b));
  days.forEach((d,i) => d.n = i+1);
  renderAdmin(); refreshAll();
}

