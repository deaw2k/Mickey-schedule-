function addClassToDay(n) {
  const day = days.find(d => d.n === n);
  day.classes.push({s: Object.keys(subjects)[0], sess: 1});
  closeModal(); editDay(n);
}

function removeClass(n, i) {
  const day = days.find(d => d.n === n);
  day.classes.splice(i,1);
  closeModal(); editDay(n);
}

function saveDayEdit(n) {
  const day = days.find(d => d.n === n);
  day.classes.forEach((c,i) => {
    const sEl = document.getElementById('ec_subj_'+n+'_'+i);
    const seEl = document.getElementById('ec_sess_'+n+'_'+i);
    if (sEl) c.s = sEl.value;
    if (seEl) c.sess = parseInt(seEl.value)||1;
  });
  closeModal(); renderAdmin(); refreshAll();
}

function deleteDay(n) {
  if (!confirm('ลบวันนี้ออกจากตาราง?')) return;
  days = days.filter(d => d.n !== n);
  days.forEach((d,i) => d.n = i+1);
  closeModal(); renderAdmin(); refreshAll();
}

function closeModal() {
  const m = document.getElementById('editModal');
  if (m) m.remove();
}

function refreshAll() {
  // Sync back to global
  Object.keys(SUBJECTS).forEach(k => delete SUBJECTS[k]);
  Object.assign(SUBJECTS, subjects);
  DAYS.length = 0;
  days.forEach(d => DAYS.push(d));
  renderMonthPills(); renderDayList(); renderSummary(); renderWeekly();
}

function copyExport() {
  const data = JSON.stringify({subjects, days});
  navigator.clipboard.writeText(data).then(() => {
    alert('Copy แล้ว! ✅\nส่งให้ Claude เพื่ออัปเดตไฟล์ได้เลย');
  }).catch(() => {
    const box = document.getElementById('exportBox');
    box.textContent = data;
    box.select && box.select();
    alert('Copy ข้อมูลจากกล่องด้านบนได้เลยครับ');
  });
}

