function getMonths() {
  const ms = ['ทั้งหมด'];
  DAYS.filter(d => !isPast(d)).forEach(d => { if (!ms.includes(d.month)) ms.push(d.month); });
  return ms;
}

function renderMonthPills() {
  const el = document.getElementById('monthPills');
  el.innerHTML = getMonths().map(m =>
    `<button class="month-pill ${m===activeMonth?'active':''}" onclick="filterMonth('${m}')">${m}</button>`
  ).join('');
}

function filterMonth(m) {
  activeMonth = m;
  renderMonthPills();
  renderDayList();
}

const monthMap = {'ม.ค.':0,'ก.พ.':1,'มี.ค.':2,'เม.ย.':3,'พ.ค.':4,'มิ.ย.':5,'ก.ค.':6,'ส.ค.':7,'ก.ย.':8,'ต.ค.':9,'พ.ย.':10,'ธ.ค.':11};

function parseDay(day) {
  const parts = day.date.split(' ');
  return new Date(parseInt(parts[2]) - 543, monthMap[parts[1]], parseInt(parts[0]));
}

function isToday(day) {
  const t = new Date();
  const d = parseDay(day);
  return t.getFullYear() === d.getFullYear() && t.getMonth() === d.getMonth() && t.getDate() === d.getDate();
}

function isPast(day) {
  const t = new Date(); t.setHours(0,0,0,0);
  const d = parseDay(day);
  return d < t;
}

function renderDayList() {
  const el = document.getElementById('dayList');
  const base = activeMonth === 'ทั้งหมด' ? DAYS : DAYS.filter(d => d.month === activeMonth);
  const filtered = base.filter(d => !isPast(d));
  if (!filtered.length) { el.innerHTML = '<div class="empty">🎉 ไม่มีคลาสที่เหลืออยู่แล้ว</div>'; return; }

  el.innerHTML = filtered.map(day => {
    const today = isToday(day);
    const color = DOW_COLORS[day.dow] || '#888';
    const bg = DOW_BG[day.dow] || '#88888822';
    const chips = day.classes.map(c => `<span class="chip" style="background:${SUBJECTS[c.s].color}">${SUBJECTS[c.s].abbr}</span>`).join('');
    const rows = day.classes.map(c => {
