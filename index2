<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f14;
    --card: #1a1a24;
    --border: #2a2a38;
    --accent1: #7c6aff;
    --accent2: #ff6a8a;
    --accent3: #6affb8;
    --accent4: #ffa96a;
    --accent5: #6ac8ff;
    --accent6: #e06aff;
    --text: #f0f0ff;
    --muted: #888899;
    --radius: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Sarabun', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding-bottom: 40px;
  }

  /* Header */
  .header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    padding: 20px 16px 16px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .avatar {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--accent1), var(--accent2));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; font-weight: 700; flex-shrink: 0;
  }
  .header-info h1 {
    font-size: 18px; font-weight: 700; line-height: 1.2;
  }
  .header-info p {
    font-size: 12px; color: var(--muted);
    margin-top: 2px;
  }
  .badge-row {
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .badge {
    font-size: 10px; font-weight: 600;
    padding: 3px 8px; border-radius: 20px;
    letter-spacing: 0.3px;
  }

  /* Tab bar */
  .tabs {
    display: flex; gap: 4px;
    background: var(--card);
    border-radius: 12px;
    padding: 4px;
    margin: 12px 16px 0;
  }
  .tab {
    flex: 1; text-align: center;
    padding: 8px 4px;
    font-size: 12px; font-weight: 600;
    border-radius: 9px;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--muted);
    background: none;
    border: none;
    font-family: 'Sarabun', sans-serif;
  }
  .tab.active {
    background: var(--accent1);
    color: #fff;
  }

  /* Section */
  .section { padding: 12px 16px 0; }

  /* Legend */
  .legend {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8px; margin-bottom: 12px;
  }
  .legend-item {
    display: flex; align-items: center; gap: 8px;
    background: var(--card);
    border-radius: 10px;
    padding: 8px 10px;
  }
  .legend-dot {
    width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
  }
  .legend-text { font-size: 11px; line-height: 1.3; }
  .legend-time { font-size: 10px; color: var(--muted); }

  /* Day card */
  .day-card {
    background: var(--card);
    border-radius: var(--radius);
    margin-bottom: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .day-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px;
    cursor: pointer;
    user-select: none;
  }
  .day-left { display: flex; align-items: center; gap: 10px; }
  .day-num {
    width: 28px; height: 28px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700;
    flex-shrink: 0;
  }
  .day-name { font-size: 14px; font-weight: 600; }
  .day-date { font-size: 11px; color: var(--muted); margin-top: 1px; }
  .day-chips { display: flex; gap: 4px; align-items: center; flex-wrap: wrap; }
  .chip {
    width: 20px; height: 20px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700; color: #000;
  }
  .chevron {
    font-size: 10px; color: var(--muted);
    transition: transform 0.2s;
  }
  .day-card.open .chevron { transform: rotate(180deg); }

  .day-body {
    display: none;
    padding: 0 14px 12px;
    border-top: 1px solid var(--border);
  }
  .day-card.open .day-body { display: block; }

  .class-row {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .class-row:last-child { border-bottom: none; }
  .class-bar {
    width: 4px; border-radius: 4px; flex-shrink: 0;
    align-self: stretch; min-height: 32px;
  }
  .class-info {}
  .class-name { font-size: 13px; font-weight: 600; }
  .class-time { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .class-session { font-size: 10px; margin-top: 3px; font-weight: 600; }

  /* Month filter */
  .month-pills {
    display: flex; gap: 6px;
    overflow-x: auto; padding-bottom: 2px;
    margin-bottom: 12px;
    scrollbar-width: none;
  }
  .month-pills::-webkit-scrollbar { display: none; }
  .month-pill {
    flex-shrink: 0;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px; font-weight: 600;
    cursor: pointer;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'Sarabun', sans-serif;
    transition: all 0.2s;
  }
  .month-pill.active {
    background: var(--accent1);
    color: #fff;
    border-color: var(--accent1);
  }

  /* Today highlight */
  .today-badge {
    font-size: 9px; background: var(--accent2);
    color: #fff; padding: 2px 6px; border-radius: 6px; font-weight: 700;
    margin-left: 4px;
  }

  /* Summary view */
  .summary-grid { display: flex; flex-direction: column; gap: 8px; }
  .summary-card {
    background: var(--card);
    border-radius: var(--radius);
    padding: 14px;
    border-left: 4px solid;
  }
  .summary-subject { font-size: 15px; font-weight: 700; }
  .summary-teacher { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .summary-detail { font-size: 12px; margin-top: 6px; display: flex; gap: 12px; flex-wrap: wrap; }
  .summary-stat { display: flex; flex-direction: column; }
  .summary-stat-val { font-size: 18px; font-weight: 700; line-height: 1; }
  .summary-stat-lbl { font-size: 10px; color: var(--muted); margin-top: 2px; }

  /* Day-of-week view */
  .dow-section { margin-bottom: 16px; }
  .dow-header {
    font-size: 12px; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 8px; padding-left: 4px;
  }

  .empty { text-align: center; color: var(--muted); font-size: 13px; padding: 30px; }
  /* Admin */
  .admin-section { margin-bottom: 20px; }
  .admin-title {
    font-size: 13px; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 10px; padding-left: 2px;
  }
  .admin-card {
    background: var(--card); border-radius: var(--radius);
    border: 1px solid var(--border); overflow: hidden;
    margin-bottom: 10px;
  }
  .admin-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px;
  }
  .admin-subject-info { display: flex; align-items: center; gap: 10px; }
  .admin-abbr {
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #000; flex-shrink: 0;
  }
  .admin-btn {
    padding: 6px 12px; border-radius: 8px; border: none;
    font-size: 12px; font-weight: 600; cursor: pointer;
    font-family: 'Sarabun', sans-serif;
  }
  .btn-edit { background: #2a2a38; color: var(--text); }
  .btn-del  { background: #ff4a4a22; color: #ff6a6a; }
  .btn-save { background: var(--accent1); color: #fff; }
  .btn-cancel { background: #2a2a38; color: var(--muted); }
  .admin-form {
    padding: 12px 14px; border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 10px;
  }
  .admin-input {
    background: var(--bg); border: 1px solid var(--border);
    color: var(--text); border-radius: 8px;
    padding: 8px 12px; font-size: 13px;
    font-family: 'Sarabun', sans-serif; width: 100%;
  }
  .admin-input:focus { outline: none; border-color: var(--accent1); }
  .admin-row { display: flex; gap: 8px; }
  .admin-add-btn {
    width: 100%; padding: 12px; border-radius: var(--radius);
    border: 2px dashed var(--border); background: none;
    color: var(--muted); font-size: 14px; font-weight: 600;
    cursor: pointer; font-family: 'Sarabun', sans-serif;
    margin-bottom: 8px;
  }
  .admin-add-btn:active { background: var(--card); }
  .admin-day-row {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 0; border-bottom: 1px solid var(--border);
  }
  .admin-day-row:last-child { border-bottom: none; }
  select.admin-input { appearance: none; }
  .export-box {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; padding: 12px;
    font-size: 10px; color: var(--muted);
    word-break: break-all; max-height: 120px; overflow-y: auto;
    font-family: monospace;
  }
  .copy-btn {
    width: 100%; padding: 10px; border-radius: 10px;
    background: var(--accent3); color: #000;
    border: none; font-size: 13px; font-weight: 700;
    cursor: pointer; font-family: 'Sarabun', sans-serif;
    margin-top: 8px;
  }

